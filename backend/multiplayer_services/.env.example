# JWT secret for signing guest tokens
# Generate with: Mac/Linux openssl rand -hex 32 | Windows PowerShell: -join ((1..32) | ForEach-Object { "{0:x2}" -f (Get-Random -Maximum 256) })
JWT_SECRET=change-this-to-a-strong-random-secret

# Redis connection
REDIS_HOST=redis
REDIS_PORT=6379

# Service ports
LOBBY_PORT=4000
GAME_PORT=4001

# Internal service URLs
GAME_SERVICE_URL=http://game-service:4001
GAME_SERVICE_WS_URL=ws://game-service:4001